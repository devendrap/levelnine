---
import { ViewTransitions } from 'astro:transitions'

interface Props {
  title?: string
}
const { title = 'ai-ui' } = Astro.props
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body style="background-color: #0B0F1A;">
    <slot />
  </body>
</html>
