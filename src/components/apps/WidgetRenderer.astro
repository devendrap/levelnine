---
import type { ResolvedWidget } from '../../lib/apps/widgets'
import EmptyState from './EmptyState.astro'

interface Props {
  widget: ResolvedWidget
}

const { widget } = Astro.props
const { type, data, props: wProps } = widget

// Chart data pre-processing
const chartLabels: string[] = type === 'chart' && data ? data.labels : []
const chartValues: number[] = type === 'chart' && data ? data.values : []
const chartTotal = chartValues.reduce((a, b) => a + b, 0)
const chartMax = chartValues.length > 0 ? Math.max(...chartValues) : 0

// Chart colors for bars
const chartColors = [
  'var(--ui-chart-1)', 'var(--ui-chart-2)', 'var(--ui-chart-3)',
  'var(--ui-chart-4)', 'var(--ui-chart-5)', 'var(--ui-accent)',
]

// Legend entries sorted by value descending (for 2-column layout)
const chartLegend = chartLabels.map((label, i) => ({
  label,
  value: chartValues[i],
  color: chartColors[i % chartColors.length],
})).sort((a, b) => b.value - a.value)
const chartUseGrid = chartLabels.length >= 6

// Workflow summary pre-processing
const wfEntries: Array<{ status: string; count: number }> = []
if (type === 'workflow_summary' && data?.statusCounts) {
  for (const [status, count] of Object.entries(data.statusCounts)) {
    wfEntries.push({ status, count: count as number })
  }
}
const wfTotal: number = type === 'workflow_summary' && data ? data.total : 0

// Status badge class helper
function statusClass(status: string): string {
  const map: Record<string, string> = {
    approved: 'ui-badge ui-badge-success',
    active: 'ui-badge ui-badge-success',
    complete: 'ui-badge ui-badge-success',
    review: 'ui-badge ui-badge-warning',
    pending: 'ui-badge ui-badge-warning',
    archived: 'ui-badge ui-badge-error',
    draft: 'ui-badge ui-badge-muted',
  }
  return map[status] ?? 'ui-badge ui-badge-muted'
}

// Workflow bar color helper
function wfBarColor(status: string): string {
  if (['approved', 'complete', 'active'].includes(status)) return 'var(--ui-success)'
  if (['review', 'pending', 'in_progress'].includes(status)) return 'var(--ui-warning)'
  if (['draft'].includes(status)) return 'var(--ui-text-placeholder)'
  return 'var(--ui-primary)'
}
---

{type === 'stats_grid' && data && (
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4" style="gap:16px">
    {(data as any[]).map((s: any) => {
      const label = s.name.replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())
      return (
        <a
          href={`/apps/${wProps.slug}/${s.name}`}
          class="ui-card ui-animate-in"
          style="display:block;height:140px;padding:20px;text-decoration:none;transition:transform 0.15s ease, box-shadow 0.15s ease"
        >
          <div style="display:flex;justify-content:space-between;align-items:flex-start">
            <span style="font-size:12px;font-weight:600;text-transform:uppercase;color:var(--ui-text-muted)">{label}</span>
          </div>
          <div style="font-size:28px;font-weight:800;color:var(--ui-primary);margin-top:16px;line-height:1">{s.total}</div>
        </a>
      )
    })}
  </div>
)}

{type === 'recent_activity' && data && (
  <div class="ui-card ui-animate-in" style="overflow:hidden">
    {(data as any[]).length === 0 ? (
      <EmptyState icon="inbox" title="No recent activity" description="Activity will appear here as records are created and updated." />
    ) : (
      <table class="ui-table">
        <thead class="ui-thead">
          <tr>
            <th class="ui-th">Name</th>
            <th class="ui-th">Type</th>
            <th class="ui-th">Status</th>
            <th class="ui-th">Updated</th>
          </tr>
        </thead>
        <tbody>
          {(data as any[]).map((item: any) => (
            <tr class="ui-tr-hover">
              <td class="ui-td">
                <a href={`/apps/${wProps.slug}/${item.typeName}/${item.id}`} style="font-weight:500;color:var(--ui-text);text-decoration:none">
                  {item.name}
                </a>
              </td>
              <td class="ui-td">
                <span style="font-size:12px;color:var(--ui-text-muted)">{item.typeName.replace(/_/g, ' ')}</span>
              </td>
              <td class="ui-td">
                <span class={statusClass(item.status)}>
                  {item.status}
                </span>
              </td>
              <td class="ui-td">
                <span style="font-size:12px;color:var(--ui-text-placeholder)">{new Date(item.updatedAt).toLocaleDateString()}</span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
)}

{type === 'chart' && data && (
  <div class="ui-card ui-animate-in" style="padding:24px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
      <h3 style="font-size:14px;font-weight:600;color:var(--ui-text)">{wProps.title}</h3>
      {chartTotal > 0 && (
        <span style="font-size:12px;color:var(--ui-text-placeholder)">{chartTotal} total</span>
      )}
    </div>
    {chartUseGrid ? (
      <div style="display:grid;grid-template-columns:2fr 1fr;gap:20px">
        {/* Left column: bar chart */}
        <div style="display:flex;flex-direction:column;gap:10px">
          {chartLabels.map((label, i) => {
            const pct = chartMax > 0 ? (chartValues[i] / chartMax) * 100 : 0
            const color = chartColors[i % chartColors.length]
            return (
              <div style="display:flex;align-items:center;gap:12px">
                <span style="font-size:12px;width:100px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--ui-text-muted)">{label}</span>
                <div style="flex:1;height:24px;border-radius:var(--ui-radius-sm);overflow:hidden;background-color:var(--ui-bg-muted)">
                  <div style={`height:100%;border-radius:var(--ui-radius-sm);width:${pct}%;background-color:${color};transition:width 0.4s ease`} />
                </div>
                <span style="font-size:12px;font-weight:600;width:36px;text-align:right;color:var(--ui-text)">{chartValues[i]}</span>
              </div>
            )
          })}
        </div>
        {/* Right column: summary legend */}
        <div style="display:flex;flex-direction:column;gap:8px;border-left:1px solid var(--ui-border);padding-left:20px">
          <span style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--ui-text-placeholder);margin-bottom:4px">Legend</span>
          {chartLegend.map((entry) => (
            <div style="display:flex;align-items:center;gap:8px">
              <span style={`width:10px;height:10px;border-radius:9999px;flex-shrink:0;background-color:${entry.color}`} />
              <span style="font-size:12px;color:var(--ui-text-muted);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">{entry.label}</span>
              <span style="font-size:12px;font-weight:600;color:var(--ui-text)">{entry.value}</span>
            </div>
          ))}
        </div>
      </div>
    ) : (
      <div style="display:flex;flex-direction:column;gap:10px">
        {chartLabels.map((label, i) => {
          const pct = chartMax > 0 ? (chartValues[i] / chartMax) * 100 : 0
          const color = chartColors[i % chartColors.length]
          return (
            <div style="display:flex;align-items:center;gap:12px">
              <span style="font-size:12px;width:100px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--ui-text-muted)">{label}</span>
              <div style="flex:1;height:24px;border-radius:var(--ui-radius-sm);overflow:hidden;background-color:var(--ui-bg-muted)">
                <div style={`height:100%;border-radius:var(--ui-radius-sm);width:${pct}%;background-color:${color};transition:width 0.4s ease`} />
              </div>
              <span style="font-size:12px;font-weight:600;width:36px;text-align:right;color:var(--ui-text)">{chartValues[i]}</span>
            </div>
          )
        })}
      </div>
    )}
  </div>
)}

{type === 'entity_list' && data && (
  <div class="ui-card ui-animate-in" style="overflow:hidden">
    {(data as any[]).length === 0 ? (
      <EmptyState icon="search" title="No records found" description="Try adjusting your filters or create a new record." />
    ) : (
      <table class="ui-table">
        <thead class="ui-thead">
          <tr>
            <th class="ui-th">Name</th>
            {(wProps.columns as string[]).map((col: string) => (
              <th class="ui-th">
                {col.replace(/_/g, ' ')}
              </th>
            ))}
            <th class="ui-th">Status</th>
          </tr>
        </thead>
        <tbody>
          {(data as any[]).map((item: any) => (
            <tr class="ui-tr-hover">
              <td class="ui-td">
                <a href={`/apps/${wProps.slug}/${wProps.entity_type}/${item.id}`} style="font-weight:500;color:var(--ui-text);text-decoration:none">
                  {item.name}
                </a>
              </td>
              {(wProps.columns as string[]).map((col: string) => (
                <td class="ui-td">
                  <span style="font-size:12px;color:var(--ui-text-muted)">{item.content?.[col] ?? '-'}</span>
                </td>
              ))}
              <td class="ui-td">
                <span class={statusClass(item.status)}>
                  {item.status}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
)}

{type === 'quick_actions' && data && (
  <div style="display:flex;flex-wrap:wrap;gap:8px">
    {(data as string[]).map((typeName: string) => {
      const label = typeName.replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())
      return (
        <a
          href={`/apps/${wProps.slug}/${typeName}/new`}
          class="ui-btn ui-btn-secondary"
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
          New {label}
        </a>
      )
    })}
  </div>
)}

{type === 'kpi_card' && data && (
  <div class="ui-card ui-animate-in" style="padding:24px;height:127px;display:flex;flex-direction:column">
    <div style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--ui-text-placeholder)">{wProps.label}</div>
    <div style="flex:1;display:flex;flex-direction:column;justify-content:flex-end">
      <div style="font-size:32px;font-weight:800;color:var(--ui-primary);line-height:1">{data.value}</div>
    </div>
  </div>
)}

{type === 'workflow_summary' && data && (
  <div class="ui-card ui-animate-in" style="padding:24px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
      <span style="font-size:14px;font-weight:600;color:var(--ui-text)">
        {(wProps.workflow_name ?? wProps.entity_type).replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())}
      </span>
      <span style="font-size:12px;color:var(--ui-text-placeholder)">{wfTotal} total</span>
    </div>
    <div style="display:flex;flex-direction:column;gap:10px">
      {wfEntries.map((entry) => {
        const pct = wfTotal > 0 ? (entry.count / wfTotal) * 100 : 0
        return (
          <div style="display:flex;align-items:center;gap:12px">
            <span style="font-size:12px;width:80px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--ui-text-muted)">{entry.status}</span>
            <div style="flex:1;height:20px;border-radius:var(--ui-radius-sm);overflow:hidden;background-color:var(--ui-bg-muted)">
              <div style={`height:100%;border-radius:var(--ui-radius-sm);width:${pct}%;background-color:${wfBarColor(entry.status)};transition:width 0.4s ease`} />
            </div>
            <span style="font-size:12px;font-weight:600;width:32px;text-align:right;color:var(--ui-text)">{entry.count}</span>
          </div>
        )
      })}
    </div>
  </div>
)}

{type === 'compliance_checklist' && data && (
  <div class="ui-card ui-animate-in" style="padding:24px">
    <h3 style="font-size:14px;font-weight:600;color:var(--ui-text);margin-bottom:4px">{data.name?.replace(/_/g, ' ')}</h3>
    <p style="font-size:12px;color:var(--ui-text-muted);margin-bottom:16px">{data.standard}</p>
    <div style="display:flex;flex-direction:column;gap:10px">
      {(data.checkpoints ?? []).map((cp: string) => (
        <div style="display:flex;align-items:flex-start;gap:10px">
          <div style="width:18px;height:18px;border-radius:4px;border:1.5px solid var(--ui-border);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="var(--ui-text-placeholder)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <span style="font-size:13px;color:var(--ui-text-muted);line-height:1.4">{cp}</span>
        </div>
      ))}
    </div>
  </div>
)}

{type === 'rich_text' && data && (
  <div class="ui-card ui-animate-in" style="padding:24px">
    <p style="font-size:13px;color:var(--ui-text-muted)">Rich text content</p>
  </div>
)}

{type === 'unknown' && (
  <div class="ui-card ui-animate-in">
    <div class="ui-empty">Unknown widget type</div>
  </div>
)}
