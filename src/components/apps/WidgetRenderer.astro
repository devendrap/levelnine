---
import type { ResolvedWidget } from '../../lib/apps/widgets'

interface Props {
  widget: ResolvedWidget
}

const { widget } = Astro.props
const { type, data, props: wProps } = widget

// Pre-process chart data
const chartLabels: string[] = type === 'chart' && data ? data.labels : []
const chartValues: number[] = type === 'chart' && data ? data.values : []
const chartMax = chartValues.length > 0 ? Math.max(...chartValues) : 0

// Pre-process workflow summary
const wfEntries: Array<{ status: string; count: number }> = []
if (type === 'workflow_summary' && data?.statusCounts) {
  for (const [status, count] of Object.entries(data.statusCounts)) {
    wfEntries.push({ status, count: count as number })
  }
}
const wfTotal: number = type === 'workflow_summary' && data ? data.total : 0
---

{type === 'stats_grid' && data && (
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
    {(data as any[]).map((s: any) => {
      const label = s.name.replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())
      return (
        <a
          href={`/apps/${wProps.slug}/${s.name}`}
          class="rounded-xl p-5 transition-all hover:opacity-90"
          style="background-color:var(--ui-bg-subtle);border:1px solid var(--ui-border)"
        >
          <div class="text-2xl font-bold" style="color:var(--ui-primary)">{s.total}</div>
          <div class="text-xs font-medium mt-1 truncate" style="color:var(--ui-text)">{label}</div>
        </a>
      )
    })}
  </div>
)}

{type === 'recent_activity' && data && (
  <div class="rounded-xl overflow-hidden" style="border:1px solid var(--ui-border)">
    {(data as any[]).length === 0 ? (
      <div class="px-6 py-10 text-center" style="background-color:var(--ui-bg-subtle)">
        <p class="text-sm" style="color:var(--ui-text-muted)">No recent activity yet.</p>
      </div>
    ) : (
      <table class="w-full">
        <thead>
          <tr style="background-color:var(--ui-bg-subtle)">
            <th class="text-left text-[11px] font-semibold uppercase tracking-wider px-5 py-3" style="color:var(--ui-text-muted)">Name</th>
            <th class="text-left text-[11px] font-semibold uppercase tracking-wider px-5 py-3" style="color:var(--ui-text-muted)">Type</th>
            <th class="text-left text-[11px] font-semibold uppercase tracking-wider px-5 py-3" style="color:var(--ui-text-muted)">Status</th>
            <th class="text-left text-[11px] font-semibold uppercase tracking-wider px-5 py-3" style="color:var(--ui-text-muted)">Updated</th>
          </tr>
        </thead>
        <tbody>
          {(data as any[]).map((item: any) => (
            <tr style="border-top:1px solid var(--ui-border)">
              <td class="px-5 py-3">
                <a
                  href={`/apps/${wProps.slug}/${item.typeName}/${item.id}`}
                  class="text-sm font-medium hover:opacity-80"
                  style="color:var(--ui-text)"
                >
                  {item.name}
                </a>
              </td>
              <td class="px-5 py-3">
                <span class="text-xs" style="color:var(--ui-text-muted)">{item.typeName.replace(/_/g, ' ')}</span>
              </td>
              <td class="px-5 py-3">
                <span
                  class="text-[11px] px-2 py-0.5 rounded-full font-medium"
                  style={`background-color:${
                    item.status === 'approved' ? 'var(--ui-success-bg)' :
                    item.status === 'review' ? 'var(--ui-warning-bg)' :
                    item.status === 'archived' ? 'var(--ui-error-bg)' :
                    'rgba(240,237,232,0.06)'
                  };color:${
                    item.status === 'approved' ? 'var(--ui-success)' :
                    item.status === 'review' ? 'var(--ui-warning)' :
                    item.status === 'archived' ? 'var(--ui-error)' :
                    'var(--ui-text-muted)'
                  }`}
                >
                  {item.status}
                </span>
              </td>
              <td class="px-5 py-3">
                <span class="text-xs" style="color:var(--ui-text-placeholder)">
                  {new Date(item.updatedAt).toLocaleDateString()}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
)}

{type === 'chart' && data && (
  <div
    class="rounded-xl p-6"
    style="background-color:var(--ui-bg-subtle);border:1px solid var(--ui-border)"
  >
    <h3 class="text-sm font-semibold mb-4" style="color:var(--ui-text)">{wProps.title}</h3>
    <div class="space-y-2">
      {chartLabels.map((label, i) => {
        const pct = chartMax > 0 ? (chartValues[i] / chartMax) * 100 : 0
        return (
          <div class="flex items-center gap-3">
            <span class="text-xs w-24 truncate" style="color:var(--ui-text-muted)">{label}</span>
            <div class="flex-1 h-5 rounded-full overflow-hidden" style="background-color:var(--ui-bg)">
              <div
                class="h-full rounded-full"
                style={`width:${pct}%;background-color:var(--ui-primary)`}
              />
            </div>
            <span class="text-xs font-medium w-8 text-right" style="color:var(--ui-text)">{chartValues[i]}</span>
          </div>
        )
      })}
    </div>
  </div>
)}

{type === 'entity_list' && data && (
  <div class="rounded-xl overflow-hidden" style="border:1px solid var(--ui-border)">
    {(data as any[]).length === 0 ? (
      <div class="px-6 py-10 text-center" style="background-color:var(--ui-bg-subtle)">
        <p class="text-sm" style="color:var(--ui-text-muted)">No records found.</p>
      </div>
    ) : (
      <table class="w-full">
        <thead>
          <tr style="background-color:var(--ui-bg-subtle)">
            <th class="text-left text-[11px] font-semibold uppercase tracking-wider px-5 py-3" style="color:var(--ui-text-muted)">Name</th>
            {(wProps.columns as string[]).map((col: string) => (
              <th class="text-left text-[11px] font-semibold uppercase tracking-wider px-5 py-3" style="color:var(--ui-text-muted)">
                {col.replace(/_/g, ' ')}
              </th>
            ))}
            <th class="text-left text-[11px] font-semibold uppercase tracking-wider px-5 py-3" style="color:var(--ui-text-muted)">Status</th>
          </tr>
        </thead>
        <tbody>
          {(data as any[]).map((item: any) => (
            <tr style="border-top:1px solid var(--ui-border)">
              <td class="px-5 py-3">
                <a
                  href={`/apps/${wProps.slug}/${wProps.entity_type}/${item.id}`}
                  class="text-sm font-medium hover:opacity-80"
                  style="color:var(--ui-text)"
                >
                  {item.name}
                </a>
              </td>
              {(wProps.columns as string[]).map((col: string) => (
                <td class="px-5 py-3">
                  <span class="text-xs" style="color:var(--ui-text-muted)">{item.content?.[col] ?? '-'}</span>
                </td>
              ))}
              <td class="px-5 py-3">
                <span
                  class="text-[11px] px-2 py-0.5 rounded-full font-medium"
                  style="background-color:rgba(240,237,232,0.06);color:var(--ui-text-muted)"
                >
                  {item.status}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
)}

{type === 'quick_actions' && data && (
  <div class="flex flex-wrap gap-2">
    {(data as string[]).map((typeName: string) => {
      const label = typeName.replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())
      return (
        <a
          href={`/apps/${wProps.slug}/${typeName}/new`}
          class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg text-xs font-medium transition-all hover:opacity-80"
          style="background-color:rgba(212,164,74,0.08);color:var(--ui-primary);border:1px solid rgba(212,164,74,0.15)"
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
          New {label}
        </a>
      )
    })}
  </div>
)}

{type === 'kpi_card' && data && (
  <div
    class="rounded-xl p-6"
    style="background-color:var(--ui-bg-subtle);border:1px solid var(--ui-border)"
  >
    <div class="text-3xl font-bold" style="color:var(--ui-primary)">{data.value}</div>
    <div class="text-xs font-medium mt-1" style="color:var(--ui-text-muted)">{wProps.label}</div>
  </div>
)}

{type === 'workflow_summary' && data && (
  <div
    class="rounded-xl p-6"
    style="background-color:var(--ui-bg-subtle);border:1px solid var(--ui-border)"
  >
    <div class="flex items-center justify-between mb-4">
      <span class="text-sm font-medium" style="color:var(--ui-text)">
        {(wProps.workflow_name ?? wProps.entity_type).replace(/_/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())}
      </span>
      <span class="text-xs" style="color:var(--ui-text-muted)">{wfTotal} total</span>
    </div>
    <div class="space-y-2">
      {wfEntries.map((entry) => {
        const pct = wfTotal > 0 ? (entry.count / wfTotal) * 100 : 0
        return (
          <div class="flex items-center gap-3">
            <span class="text-xs w-20 truncate" style="color:var(--ui-text-muted)">{entry.status}</span>
            <div class="flex-1 h-4 rounded-full overflow-hidden" style="background-color:var(--ui-bg)">
              <div
                class="h-full rounded-full"
                style={`width:${pct}%;background-color:${
                  entry.status === 'approved' || entry.status === 'complete' ? 'var(--ui-success)' :
                  entry.status === 'review' || entry.status === 'pending' ? 'var(--ui-warning)' :
                  entry.status === 'draft' ? 'var(--ui-text-placeholder)' :
                  'var(--ui-primary)'
                }`}
              />
            </div>
            <span class="text-xs font-medium w-8 text-right" style="color:var(--ui-text)">{entry.count}</span>
          </div>
        )
      })}
    </div>
  </div>
)}

{type === 'compliance_checklist' && data && (
  <div
    class="rounded-xl p-6"
    style="background-color:var(--ui-bg-subtle);border:1px solid var(--ui-border)"
  >
    <h3 class="text-sm font-semibold mb-1" style="color:var(--ui-text)">{data.name?.replace(/_/g, ' ')}</h3>
    <p class="text-xs mb-4" style="color:var(--ui-text-muted)">{data.standard}</p>
    <div class="space-y-2">
      {(data.checkpoints ?? []).map((cp: string) => (
        <div class="flex items-center gap-2">
          <div class="w-4 h-4 rounded border flex items-center justify-center" style="border-color:var(--ui-border)">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="var(--ui-text-placeholder)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <span class="text-xs" style="color:var(--ui-text-muted)">{cp}</span>
        </div>
      ))}
    </div>
  </div>
)}

{type === 'rich_text' && data && (
  <div
    class="rounded-xl p-6"
    style="background-color:var(--ui-bg-subtle);border:1px solid var(--ui-border)"
  >
    <p class="text-sm" style="color:var(--ui-text-muted)">Rich text content</p>
  </div>
)}

{type === 'unknown' && (
  <div
    class="rounded-xl p-6 text-center"
    style="background-color:var(--ui-bg-subtle);border:1px solid var(--ui-border)"
  >
    <p class="text-sm" style="color:var(--ui-text-muted)">Unknown widget type</p>
  </div>
)}
