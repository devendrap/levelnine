---
interface Props {
  title?: string
  description?: string
  actionLabel?: string
  actionHref?: string
  icon?: 'search' | 'folder' | 'inbox' | 'plus'
}
const { title = 'Nothing here yet', description = '', actionLabel, actionHref, icon = 'inbox' } = Astro.props
---

<div class="ui-empty">
  <div style="margin-bottom:12px;color:var(--ui-text-placeholder)">
    {icon === 'search' && (
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
    )}
    {icon === 'folder' && (
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
      </svg>
    )}
    {icon === 'inbox' && (
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="22 12 16 12 14 15 10 15 8 12 2 12" />
        <path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z" />
      </svg>
    )}
    {icon === 'plus' && (
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10" />
        <line x1="12" y1="8" x2="12" y2="16" />
        <line x1="8" y1="12" x2="16" y2="12" />
      </svg>
    )}
  </div>
  <div class="ui-empty-title">{title}</div>
  {description && <div class="ui-empty-description">{description}</div>}
  {actionLabel && actionHref && (
    <a href={actionHref} class="ui-btn ui-btn-primary">{actionLabel}</a>
  )}
</div>
