---
interface Props {
  currentPage: number
  totalPages: number
  baseUrl: string
}

const { currentPage, totalPages, baseUrl } = Astro.props

function getPageNumbers(current: number, total: number): (number | '...')[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1)
  const pages: (number | '...')[] = [1]
  if (current > 3) pages.push('...')
  for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) {
    pages.push(i)
  }
  if (current < total - 2) pages.push('...')
  pages.push(total)
  return pages
}

const pages = getPageNumbers(currentPage, totalPages)
const prevDisabled = currentPage <= 1
const nextDisabled = currentPage >= totalPages
---

<div style="display:flex; align-items:center; justify-content:center; padding:8px 16px">
  <div class="ui-pagination">
    {/* Prev button */}
    <a
      href={prevDisabled ? undefined : `${baseUrl}${currentPage - 1}`}
      class:list={['ui-pagination-item', 'ui-pagination-nav', { 'ui-pagination-disabled': prevDisabled }]}
      style="border-right:1px solid var(--ui-border)"
      aria-label="Previous page"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M15 18l-6-6 6-6" />
      </svg>
    </a>

    {/* Page numbers */}
    {pages.map((p) =>
      p === '...' ? (
        <span class="ui-pagination-item ui-pagination-ellipsis">...</span>
      ) : (
        <a
          href={`${baseUrl}${p}`}
          class:list={['ui-pagination-item', 'ui-pagination-page', { 'ui-pagination-active': p === currentPage }]}
          aria-label={`Page ${p}`}
          aria-current={p === currentPage ? 'page' : undefined}
        >
          {p}
        </a>
      )
    )}

    {/* Next button */}
    <a
      href={nextDisabled ? undefined : `${baseUrl}${currentPage + 1}`}
      class:list={['ui-pagination-item', 'ui-pagination-nav', { 'ui-pagination-disabled': nextDisabled }]}
      aria-label="Next page"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M9 6l6 6-6 6" />
      </svg>
    </a>
  </div>
</div>

<style>
  .ui-pagination {
    display: inline-flex;
    align-items: stretch;
    border-radius: var(--ui-radius-md);
    border: 1px solid var(--ui-border);
    background: var(--ui-card-bg);
    overflow: hidden;
  }

  .ui-pagination-item {
    height: 32px;
    min-width: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .ui-pagination-nav {
    padding: 0 10px;
    color: var(--ui-text-muted);
  }

  .ui-pagination-nav:hover:not(.ui-pagination-disabled) {
    background-color: var(--ui-bg-hover);
  }

  .ui-pagination-disabled {
    color: var(--ui-text-placeholder);
    pointer-events: none;
    opacity: 0.5;
  }

  .ui-pagination-ellipsis {
    color: var(--ui-text-placeholder);
    border-right: 1px solid var(--ui-border);
  }

  .ui-pagination-page {
    font-weight: 500;
    color: var(--ui-text-muted);
    border-right: 1px solid var(--ui-border);
  }

  .ui-pagination-page:hover:not(.ui-pagination-active) {
    background-color: var(--ui-bg-hover);
  }

  .ui-pagination-active {
    background-color: var(--ui-primary-light);
    color: var(--ui-primary);
    font-weight: 600;
  }
</style>
