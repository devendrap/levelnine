---
interface Props {
  users: Array<{ name: string; color?: string }>
  max?: number
  size?: 'sm' | 'md' | 'lg'
}

const { users, max = 5, size = 'md' } = Astro.props

const sizes = { sm: 24, md: 32, lg: 40 }
const fontSizes = { sm: '9px', md: '11px', lg: '13px' }
const px = sizes[size]
const fontSize = fontSizes[size]
const visible = users.slice(0, max)
const overflow = users.length - max
---

<div style="display:flex">
  {visible.map((user, i) => (
    <div
      style={`width:${px}px;height:${px}px;border-radius:50%;display:flex;align-items:center;justify-content:center;background-color:${user.color || 'var(--ui-primary)'};color:var(--ui-text-on-primary);font-size:${fontSize};font-weight:700;border:2px solid var(--ui-card-bg);margin-left:${i > 0 ? '-8px' : '0'};position:relative;z-index:${visible.length - i};flex-shrink:0;`}
      title={user.name}
    >
      {user.name.charAt(0).toUpperCase()}
    </div>
  ))}
  {overflow > 0 && (
    <div
      style={`width:${px}px;height:${px}px;border-radius:50%;display:flex;align-items:center;justify-content:center;background-color:var(--ui-bg-muted);color:var(--ui-text-muted);font-size:${fontSize};font-weight:600;border:2px solid var(--ui-card-bg);margin-left:-8px;position:relative;z-index:0;flex-shrink:0;`}
    >
      +{overflow}
    </div>
  )}
</div>
