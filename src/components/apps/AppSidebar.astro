---
import type { Container, EntityType } from '../../../server/core/types/index'
import { getAllUIConfigs } from '../../lib/apps/helpers'

interface Props {
  container: Container
  entityTypes: EntityType[]
  activeType?: string
  activePage?: string
  pages?: any[]
  userRole?: string
}

const { container, entityTypes, activeType, activePage, pages, userRole } = Astro.props
const slug = container.slug!
let navigation = container.manifest?.navigation ?? []

const typeNames = new Set(entityTypes.map(et => et.name))

if (navigation.length === 0) {
  const uiConfigs = await getAllUIConfigs(container.id)
  const configsWithNav = uiConfigs.filter(c => c.navigation)
  if (configsWithNav.length > 0) {
    const groups = new Map<string, { label: string; children: string[]; sortOrder: number }>()
    const sorted = [...configsWithNav].sort((a, b) => (a.navigation?.sort_order ?? 99) - (b.navigation?.sort_order ?? 99))
    for (const cfg of sorted) {
      const group = cfg.navigation?.menu_group ?? 'Main'
      if (!groups.has(group)) groups.set(group, { label: group, children: [], sortOrder: cfg.navigation?.sort_order ?? 99 })
      groups.get(group)!.children.push(cfg.entity_type)
    }
    navigation = [...groups.values()].sort((a, b) => a.sortOrder - b.sortOrder)
  }
}

const hasNav = navigation.length > 0
const defaultPage = (pages ?? []).find((p: any) => p.is_default)
const customPages = (pages ?? []).filter((p: any) => !p.is_default)
const hasCustomPages = customPages.length > 0
const isAdmin = userRole === 'admin'
const isDashboard = !activeType && !activePage

// Contextual icons for known page names
const PAGE_ICONS: Record<string, string> = {
  home: 'M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z M9 22V12h6v10',
  analytics: 'M18 20V10 M12 20V4 M6 20v-6',
  compliance: 'M9 11l3 3L22 4 M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11',
  team_overview: 'M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4-4v2 M23 21v-2a4 4 0 00-3-3.87',
}
---

<aside
  class="shrink-0 flex flex-col h-full overflow-hidden"
  style="width:260px;background-color:var(--ui-bg-subtle);border-right:1px solid var(--ui-border)"
>
  <!-- App branding -->
  <div style="padding:20px 20px 16px;border-bottom:1px solid var(--ui-border)">
    <a href={`/apps/${slug}`} class="flex items-center gap-3" style="text-decoration:none">
      <div
        class="shrink-0 flex items-center justify-center"
        style="width:32px;height:32px;border-radius:var(--ui-radius-md);background-color:var(--ui-primary);box-shadow:var(--ui-shadow-md)"
      >
        <span style="font-size:13px;font-weight:800;color:var(--ui-bg)">{container.name.charAt(0)}</span>
      </div>
      <div class="min-w-0">
        <h2 class="truncate" style="font-size:14px;font-weight:700;color:var(--ui-text);line-height:1.3">{container.name}</h2>
        {container.description && (
          <p class="truncate" style="font-size:11px;color:var(--ui-text-placeholder);line-height:1.3">{container.description}</p>
        )}
      </div>
    </a>
  </div>

  <!-- Scrollable nav -->
  <nav class="flex-1 overflow-y-auto" style="padding:12px">
    <!-- Dashboard -->
    <a href={`/apps/${slug}`} class={isDashboard ? 'ui-nav-item ui-nav-item--active' : 'ui-nav-item'}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d={PAGE_ICONS.home} />
      </svg>
      {defaultPage ? defaultPage.label : 'Dashboard'}
    </a>

    <!-- Custom pages -->
    {hasCustomPages && (
      <div style="margin-top:16px">
        <div style="padding:0 12px;margin-bottom:6px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--ui-text-placeholder)">
          Pages
        </div>
        {customPages.map((page: any) => {
          const isActive = activePage === page.route
          const icon = PAGE_ICONS[page.name]
          return (
            <a href={`/apps/${slug}/p/${page.route}`} class={isActive ? 'ui-nav-item ui-nav-item--active' : 'ui-nav-item'}>
              {icon ? (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d={icon} />
                </svg>
              ) : (
                <span class="shrink-0" style={`width:8px;height:8px;border-radius:50%;background-color:${isActive ? 'var(--ui-primary)' : 'var(--ui-text-placeholder)'};opacity:${isActive ? '1' : '0.4'}`} />
              )}
              {page.label}
            </a>
          )
        })}
      </div>
    )}

    <!-- Divider -->
    {(hasCustomPages || defaultPage) && (hasNav || entityTypes.length > 0) && (
      <div style="border-top:1px solid var(--ui-border);margin:12px 8px" />
    )}

    <!-- Entity type navigation -->
    {hasNav ? (
      navigation.map((group) => (
        <div style="margin-top:12px">
          <div style="padding:0 12px;margin-bottom:6px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--ui-text-placeholder)">
            {group.label}
          </div>
          {group.children.filter(name => typeNames.has(name)).map((name) => {
            const isActive = activeType === name
            const label = name.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase())
            return (
              <a href={`/apps/${slug}/${name}`} class={isActive ? 'ui-nav-item ui-nav-item--active' : 'ui-nav-item'}>
                <span class="shrink-0" style={`width:8px;height:8px;border-radius:50%;background-color:${isActive ? 'var(--ui-primary)' : 'var(--ui-text-placeholder)'};opacity:${isActive ? '1' : '0.4'}`} />
                {label}
              </a>
            )
          })}
        </div>
      ))
    ) : (
      <div style="margin-top:4px">
        <div style="padding:0 12px;margin-bottom:6px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--ui-text-placeholder)">
          Entity Types
        </div>
        {entityTypes.map((et) => {
          const isActive = activeType === et.name
          const label = et.name.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase())
          return (
            <a href={`/apps/${slug}/${et.name}`} class={isActive ? 'ui-nav-item ui-nav-item--active' : 'ui-nav-item'}>
              <span class="shrink-0" style={`width:8px;height:8px;border-radius:50%;background-color:${isActive ? 'var(--ui-primary)' : 'var(--ui-text-placeholder)'};opacity:${isActive ? '1' : '0.4'}`} />
              {label}
            </a>
          )
        })}
      </div>
    )}

    <!-- Admin -->
    {isAdmin && (
      <div style="margin-top:12px">
        <div style="border-top:1px solid var(--ui-border);margin:4px 8px 12px" />
        <div style="padding:0 12px;margin-bottom:6px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--ui-text-placeholder)">
          Admin
        </div>
        <a href={`/apps/${slug}/admin/users`} class={activePage === 'admin-users' ? 'ui-nav-item ui-nav-item--active' : 'ui-nav-item'}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4-4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87" /><path d="M16 3.13a4 4 0 010 7.75" />
          </svg>
          Users
        </a>
        <a href={`/apps/${slug}/admin/settings`} class={activePage === 'admin-settings' ? 'ui-nav-item ui-nav-item--active' : 'ui-nav-item'}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06A1.65 1.65 0 0019.32 9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z" />
          </svg>
          Settings
        </a>
      </div>
    )}
  </nav>

  <!-- Footer -->
  <div style="padding:12px 20px;border-top:1px solid var(--ui-border);display:flex;align-items:center;gap:8px">
    <a href="/dashboard" style="display:flex;align-items:center;gap:6px;text-decoration:none">
      <img src="/icon.png" alt="LevelNine" style="height:16px;opacity:0.4" />
      <span style="font-size:10px;color:var(--ui-text-placeholder);opacity:0.6">LevelNine</span>
    </a>
  </div>
</aside>
