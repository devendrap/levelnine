---
import type { Container, EntityType } from '../../../server/core/types/index'
import { getAllUIConfigs } from '../../lib/apps/helpers'

interface Props {
  container: Container
  entityTypes: EntityType[]
  activeType?: string
  activePage?: string
  pages?: any[]
  userRole?: string
}

const { container, entityTypes, activeType, activePage, pages, userRole } = Astro.props
const slug = container.slug!
let navigation = container.manifest?.navigation ?? []

// Build a set of entity type names that exist in the DB
const typeNames = new Set(entityTypes.map(et => et.name))

// If no manifest navigation, try D10 ui_configs for navigation grouping
if (navigation.length === 0) {
  const uiConfigs = await getAllUIConfigs(container.id)
  const configsWithNav = uiConfigs.filter(c => c.navigation)
  if (configsWithNav.length > 0) {
    const groups = new Map<string, { label: string; children: string[]; sortOrder: number }>()
    const sorted = [...configsWithNav].sort((a, b) => (a.navigation?.sort_order ?? 99) - (b.navigation?.sort_order ?? 99))
    for (const cfg of sorted) {
      const group = cfg.navigation?.menu_group ?? 'Main'
      if (!groups.has(group)) groups.set(group, { label: group, children: [], sortOrder: cfg.navigation?.sort_order ?? 99 })
      groups.get(group)!.children.push(cfg.entity_type)
    }
    navigation = [...groups.values()].sort((a, b) => a.sortOrder - b.sortOrder)
  }
}

const hasNav = navigation.length > 0

// Separate default page from custom pages
const defaultPage = (pages ?? []).find((p: any) => p.is_default)
const customPages = (pages ?? []).filter((p: any) => !p.is_default)
const hasCustomPages = customPages.length > 0
const isAdmin = userRole === 'admin'

// Check if we're on dashboard (no activeType and no activePage)
const isDashboard = !activeType && !activePage
---

<aside
  class="shrink-0 flex flex-col h-full overflow-y-auto"
  style="width:260px;background-color:var(--ui-bg-subtle);border-right:1px solid var(--ui-border)"
>
  <!-- App name -->
  <div class="px-5 py-4" style="border-bottom:1px solid var(--ui-border)">
    <a href={`/apps/${slug}`} class="block">
      <h2 class="text-sm font-bold truncate" style="color:var(--ui-text)">
        {container.name}
      </h2>
      {container.description && (
        <p class="text-[11px] mt-0.5 truncate" style="color:var(--ui-text-muted)">
          {container.description}
        </p>
      )}
    </a>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 px-3 py-3 space-y-4">
    <!-- Home / Dashboard link -->
    <a
      href={`/apps/${slug}`}
      class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs font-medium transition-all"
      style={isDashboard
        ? "background-color:rgba(212,164,74,0.1);color:var(--ui-primary)"
        : "color:var(--ui-text-muted)"
      }
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      {defaultPage ? defaultPage.label : 'Dashboard'}
    </a>

    <!-- Custom pages section -->
    {hasCustomPages && (
      <div>
        <div
          class="px-3 py-1.5 text-[10px] font-semibold uppercase tracking-wider"
          style="color:var(--ui-text-placeholder)"
        >
          Pages
        </div>
        <div class="space-y-0.5 mt-1">
          {customPages.map((page: any) => {
            const isActive = activePage === page.route
            return (
              <a
                href={`/apps/${slug}/p/${page.route}`}
                class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs transition-all"
                style={isActive
                  ? "background-color:rgba(212,164,74,0.1);color:var(--ui-primary);font-weight:600"
                  : "color:var(--ui-text-muted)"
                }
              >
                <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background-color:${isActive ? 'var(--ui-primary)' : 'var(--ui-border)'}`} />
                {page.label}
              </a>
            )
          })}
        </div>
      </div>
    )}

    <!-- Divider before entity types (if we have pages) -->
    {(hasCustomPages || defaultPage) && (hasNav || entityTypes.length > 0) && (
      <div style="border-top:1px solid var(--ui-border);margin:8px 12px" />
    )}

    <!-- Entity type navigation -->
    {hasNav ? (
      /* Grouped navigation from manifest / D10 */
      navigation.map((group) => (
        <div>
          <div
            class="px-3 py-1.5 text-[10px] font-semibold uppercase tracking-wider"
            style="color:var(--ui-text-placeholder)"
          >
            {group.label}
          </div>
          <div class="space-y-0.5 mt-1">
            {group.children.filter(name => typeNames.has(name)).map((name) => {
              const isActive = activeType === name
              const label = name.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase())
              return (
                <a
                  href={`/apps/${slug}/${name}`}
                  class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs transition-all"
                  style={isActive
                    ? "background-color:rgba(212,164,74,0.1);color:var(--ui-primary);font-weight:600"
                    : "color:var(--ui-text-muted)"
                  }
                >
                  <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background-color:${isActive ? 'var(--ui-primary)' : 'var(--ui-border)'}`} />
                  {label}
                </a>
              )
            })}
          </div>
        </div>
      ))
    ) : (
      /* Flat list of all entity types */
      <div class="space-y-0.5">
        {entityTypes.map((et) => {
          const isActive = activeType === et.name
          const label = et.name.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase())
          return (
            <a
              href={`/apps/${slug}/${et.name}`}
              class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs transition-all"
              style={isActive
                ? "background-color:rgba(212,164,74,0.1);color:var(--ui-primary);font-weight:600"
                : "color:var(--ui-text-muted)"
              }
            >
              <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background-color:${isActive ? 'var(--ui-primary)' : 'var(--ui-border)'}`} />
              {label}
            </a>
          )
        })}
      </div>
    )}

    <!-- Admin section -->
    {isAdmin && (
      <div>
        <div style="border-top:1px solid var(--ui-border);margin:8px 12px" />
        <div
          class="px-3 py-1.5 text-[10px] font-semibold uppercase tracking-wider"
          style="color:var(--ui-text-placeholder)"
        >
          Admin
        </div>
        <div class="space-y-0.5 mt-1">
          <a
            href={`/apps/${slug}/admin/users`}
            class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs transition-all"
            style={activePage === 'admin-users'
              ? "background-color:rgba(212,164,74,0.1);color:var(--ui-primary);font-weight:600"
              : "color:var(--ui-text-muted)"
            }
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4-4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 00-3-3.87"/>
              <path d="M16 3.13a4 4 0 010 7.75"/>
            </svg>
            Users
          </a>
          <a
            href={`/apps/${slug}/admin/settings`}
            class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-xs transition-all"
            style={activePage === 'admin-settings'
              ? "background-color:rgba(212,164,74,0.1);color:var(--ui-primary);font-weight:600"
              : "color:var(--ui-text-muted)"
            }
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="3"/>
              <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06A1.65 1.65 0 0019.32 9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/>
            </svg>
            Settings
          </a>
        </div>
      </div>
    )}
  </nav>

  <!-- Footer -->
  <div class="px-5 py-3" style="border-top:1px solid var(--ui-border)">
    <a href="/dashboard">
      <img src="/icon.png" alt="LevelNine" style="height:18px;opacity:0.5" />
    </a>
  </div>
</aside>
