---
import type { Container } from '../../lib/containers/types'
import SidebarCreateForm from './SidebarCreateForm.tsx'
import SidebarDeleteDialog from './SidebarDeleteDialog.tsx'
import { SidebarProgress } from '../../islands/ManifestCountIsland'
import { statusBadgeStyle } from '../../lib/ui-colors'

interface Props {
  containers: Container[]
  selectedId?: string
}

const { containers, selectedId } = Astro.props
---

<aside
  class="w-80 flex flex-col border-r shrink-0"
  style="background-color:rgba(11,15,26,0.6);border-color:var(--ui-border)"
>
  <!-- Header -->
  <div class="flex items-center justify-between px-5 py-4 border-b" style="border-color:var(--ui-border)">
    <div class="flex items-center gap-3">
      <a
        href="/dashboard"
        class="w-8 h-8 rounded-lg flex items-center justify-center hover:opacity-80 transition-opacity"
        style="background-color:rgba(240,237,232,0.06)"
        title="Back to Dashboard"
      >
        <span style="color:var(--ui-text-muted);font-size:14px">&larr;</span>
      </a>
      <div>
        <h2 class="text-sm font-semibold tracking-tight" style="color:var(--ui-text)">Containers</h2>
        <p class="text-[10px]" style="color:var(--ui-text-muted)">Industry definitions</p>
      </div>
    </div>
  </div>

  <!-- Container list -->
  <div class="flex-1 overflow-y-auto px-3 py-2">
    {containers.map((c) => (
      <div
        class="sidebar-container-item group relative rounded-lg mb-1 transition-all"
        style={`background-color:${selectedId === c.id ? 'rgba(212,164,74,0.08)' : 'transparent'};border-left:2px solid ${selectedId === c.id ? 'var(--ui-primary)' : 'transparent'}`}
      >
        <a
          href={`/containers/${c.id}`}
          class="block w-full text-left px-3 py-3 no-underline"
        >
          <div class="flex items-center justify-between mb-0.5">
            <span
              class="text-sm font-medium truncate"
              style={`color:${selectedId === c.id ? 'var(--ui-text)' : 'var(--ui-text-muted)'}`}
            >
              {c.name}
            </span>
            <span class="text-[10px] uppercase font-semibold px-1.5 py-0.5 rounded mr-6" style={statusBadgeStyle(c.status)}>
              {c.status}
            </span>
          </div>
          {c.manifest?.entity_types?.length ? (
            selectedId === c.id ? (
              <SidebarProgress
                client:only="solid-js"
                initialReady={c.manifest.entity_types!.filter(e => e.schema).length}
                initialTotal={c.manifest.entity_types!.length}
              />
            ) : (
              <div class="flex items-center gap-1.5 mt-1">
                <div class="h-1 rounded-full flex-1" style="background-color:rgba(240,237,232,0.06)">
                  <div
                    class="h-1 rounded-full transition-all"
                    style={`background-color:var(--ui-primary);width:${(c.manifest.entity_types!.filter(e => e.schema).length / c.manifest.entity_types!.length) * 100}%`}
                  />
                </div>
                <span class="text-[10px] tabular-nums" style="color:var(--ui-text-muted)">
                  {c.manifest.entity_types!.filter(e => e.schema).length}/{c.manifest.entity_types!.length}
                </span>
              </div>
            )
          ) : null}
        </a>
        <!-- Plain HTML delete button — no island needed -->
        <button
          class="sidebar-delete-btn absolute top-2.5 right-2 w-6 h-6 rounded flex items-center justify-center cursor-pointer opacity-0 group-hover:opacity-100 transition-opacity"
          style="background:none;border:none;color:var(--ui-text-muted)"
          data-id={c.id}
          data-name={c.name}
          title="Delete container"
        >
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="3 6 5 6 21 6" />
            <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2" />
            <line x1="10" y1="11" x2="10" y2="17" />
            <line x1="14" y1="11" x2="14" y2="17" />
          </svg>
        </button>
      </div>
    ))}
  </div>

  <!-- Footer -->
  <div class="px-3 py-3 border-t space-y-2" style="border-color:var(--ui-border)">
    <SidebarCreateForm client:only="solid-js" />
  </div>

  <!-- Single shared dialog island for the entire sidebar -->
  <SidebarDeleteDialog client:only="solid-js" />
</aside>

<style>
  .sidebar-delete-btn:hover {
    background-color: rgba(239, 68, 68, 0.15) !important;
    color: #EF4444 !important;
  }
</style>

<script>
  document.querySelector('.flex-1.overflow-y-auto')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.sidebar-delete-btn') as HTMLElement
    if (!btn) return
    e.preventDefault()
    e.stopPropagation()
    window.dispatchEvent(new CustomEvent('delete-container', { detail: { id: btn.dataset.id, name: btn.dataset.name } }))
  })
</script>
