---
import type { Container } from '../../lib/containers/types'
import ManifestTableIsland from '../../islands/ManifestTableIsland.tsx'

interface Props {
  container: Container
}

const { container } = Astro.props
const entityTypes = container.manifest?.entity_types ?? []
---

<ManifestTableIsland
  client:only="solid-js"
  containerId={container.id}
  containerStatus={container.status}
  containerSlug={container.slug ?? undefined}
  entityTypes={entityTypes}
/>
