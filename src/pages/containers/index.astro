---
import Base from '../../layouts/Base.astro'
import Sidebar from '../../components/containers/Sidebar.astro'
import SidebarCreateForm from '../../components/containers/SidebarCreateForm.tsx'
import { CM_STYLES } from '../../lib/containers/styles'
import { authenticate } from '../../../server/middleware/auth'
import * as containerService from '../../../server/modules/containers/service'
import '../../index.css'

let containers: any[] = []
try {
  authenticate(Astro.request)
  containers = await containerService.listContainers()
} catch {
  return Astro.redirect('/login')
}
---

<Base title="LevelNine — Container Manager">
  <style is:inline set:html={CM_STYLES} />
  <div class="dark flex h-screen" style="background-color:var(--ui-bg);font-family:var(--ui-font)">
    <div id="sidebar-wrapper" class="shrink-0 flex" style="transition:margin-left 0.2s ease">
      <Sidebar containers={containers} />
    </div>

    <!-- Empty state -->
    <main class="flex-1 flex flex-col min-w-0">
      <div class="shrink-0 px-4 py-3">
        <button
          id="sidebar-toggle"
          class="w-10 h-10 flex items-center justify-center cursor-pointer hover:opacity-80 transition-opacity"
          style="color:var(--ui-text-muted);background:none;border:none"
          title="Toggle sidebar"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M3 6h18M3 12h18M3 18h18" />
          </svg>
        </button>
      </div>
      <div class="flex-1 flex items-center justify-center">
      <div class="text-center max-w-md">
        <div
          class="w-16 h-16 rounded-2xl mx-auto mb-5 flex items-center justify-center"
          style="background-color:rgba(212,164,74,0.08)"
        >
          <span style="font-size:28px;color:var(--ui-primary)">&#9881;</span>
        </div>
        <h1 class="text-xl font-semibold mb-2" style="color:var(--ui-text)">
          Container Manager
        </h1>
        <p class="text-sm leading-relaxed mb-8" style="color:var(--ui-text-muted)">
          Define industry-specific applications through AI-guided conversation.
          Each container becomes a complete workflow with forms, navigation, and business rules.
        </p>
        <SidebarCreateForm client:only="solid-js" />
      </div>
      </div>
    </main>
  </div>

  <script is:inline>
    const toggle = document.getElementById('sidebar-toggle')
    const wrapper = document.getElementById('sidebar-wrapper')
    if (toggle && wrapper) {
      const sidebar = wrapper.querySelector('aside')
      let collapsed = false
      toggle.addEventListener('click', () => {
        collapsed = !collapsed
        if (sidebar) {
          wrapper.style.marginLeft = collapsed ? `-${sidebar.offsetWidth}px` : '0'
        }
      })
    }
  </script>
</Base>
