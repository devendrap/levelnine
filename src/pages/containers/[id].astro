---
import Base from '../../layouts/Base.astro'
import Sidebar from '../../components/containers/Sidebar.astro'
import ContainerHeader from '../../components/containers/ContainerHeader.astro'
import ManifestTab from '../../components/containers/ManifestTab.astro'
import ChatPanel from '../../components/containers/ChatPanel.tsx'
import ExplorationPanel from '../../components/containers/ExplorationPanel.tsx'
import { CM_STYLES } from '../../lib/containers/styles'
import { authenticate } from '../../../server/middleware/auth'
import * as containerService from '../../../server/modules/containers/service'
import type { Container, Message } from '../../lib/containers/types'
import '../../index.css'

const { id } = Astro.params
const tab = (Astro.url.searchParams.get('tab') ?? 'chat') as 'chat' | 'manifest' | 'explore'
const enhanceName = Astro.url.searchParams.get('enhance')
const action = Astro.url.searchParams.get('action')

let containers: any[] = []
let container: Container
let messages: Message[] = []

try {
  authenticate(Astro.request)
  containers = await containerService.listContainers()
  container = await containerService.getContainer(id!) as any
  messages = await containerService.getMessages(id!) as any
} catch (e: any) {
  if (e.message === 'No token provided' || e.message === 'Invalid token') {
    return Astro.redirect('/login')
  }
  return Astro.redirect('/containers')
}

// Build pre-filled input or auto-send message from URL params
let initialInput = ''
let autoSend = ''

if (enhanceName) {
  const template = import.meta.env.ENHANCE_PROMPT ?? 'Generate a complete type package for "{{name}}". Respond with a JSON object containing: ui_spec (ai-ui rendering spec using {type, props, children} nodes), data_schema (JSON Schema for direct fields only — no embedded related types), field_metadata (default/searchable/sortable/show_in_list per field), related_types (from manifest relations), document_slots (from manifest documents), report_relevance (from manifest reports). Use components: Container, Tabs, Stack, Grid, Select, DatePicker, FileUpload, RichText, Table, Input, TextArea, Badge. Make it production-ready.'
  initialInput = template.replace(/\{\{name\}\}/g, enhanceName)
}

if (action === 'generate-schemas') {
  const entityTypes = container.manifest?.entity_types ?? []
  const missing = entityTypes.filter(et => !et.schema)
  if (missing.length > 0) {
    const batch = missing.slice(0, 3)
    const names = batch.map(e => e.name)
    const template = import.meta.env.GENERATE_SCHEMAS_PROMPT ?? 'Generate complete type packages for these {{count}} entity types: {{names}}\n\nFor each type, produce a JSON object with: ui_spec ({type, props, children} nodes), data_schema (JSON Schema — direct fields only, no embedded related types), field_metadata, related_types, document_slots, report_relevance.\n\nIMPORTANT: In the json:entity_types summary block at the end, include ONLY these {{count}} entity types with their type packages. Do NOT include the other {{remaining}} entity types.'
    autoSend = template
      .replace(/\{\{count\}\}/g, String(batch.length))
      .replace(/\{\{names\}\}/g, names.join(', '))
      .replace(/\{\{remaining\}\}/g, String(entityTypes.length - batch.length))
  }
}
---

<Base title={`ai-ui — ${container.name}`}>
  <style is:inline set:html={CM_STYLES} />
  <div class="dark flex h-screen" style="background-color:var(--ui-bg);font-family:var(--ui-font)">
    {/* Sidebar with collapse support */}
    <div id="sidebar-wrapper" class="shrink-0 flex" style="transition:margin-left 0.2s ease">
      <Sidebar containers={containers} selectedId={id} />
    </div>

    <main class="flex-1 flex flex-col min-w-0">
      {/* Header with hamburger */}
      <div class="flex items-center shrink-0">
        <button
          id="sidebar-toggle"
          class="w-10 h-10 flex items-center justify-center cursor-pointer hover:opacity-80 transition-opacity shrink-0 ml-2"
          style="color:var(--ui-text-muted);background:none;border:none"
          aria-label="Toggle sidebar"
          title="Toggle sidebar"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M3 6h18M3 12h18M3 18h18" />
          </svg>
        </button>
        <div class="flex-1 min-w-0">
          <ContainerHeader container={container} activeTab={tab} />
        </div>
      </div>

      {tab === 'chat' ? (
        <ChatPanel
          client:only="solid-js"
          containerId={id!}
          containerStatus={container.status}
          initialMessages={messages}
          initialInput={initialInput || undefined}
          autoSend={autoSend || undefined}
        />
      ) : tab === 'explore' ? (
        <ExplorationPanel
          client:only="solid-js"
          containerId={id!}
          containerStatus={container.status}
        />
      ) : (
        <ManifestTab container={container} />
      )}
    </main>
  </div>

  <script is:inline>
    const toggle = document.getElementById('sidebar-toggle')
    const wrapper = document.getElementById('sidebar-wrapper')
    if (toggle && wrapper) {
      const sidebar = wrapper.querySelector('aside')
      let collapsed = false
      toggle.addEventListener('click', () => {
        collapsed = !collapsed
        if (sidebar) {
          wrapper.style.marginLeft = collapsed ? `-${sidebar.offsetWidth}px` : '0'
        }
      })
    }
  </script>
</Base>
