---
import AppLayout from '../../../../layouts/AppLayout.astro'
import AppEntityFormIsland from '../../../../islands/AppEntityFormIsland.tsx'
import { loadAppContext } from '../../../../lib/apps/helpers'

const ctx = await loadAppContext(Astro)
if (ctx instanceof Response) return ctx
const { container, entityTypes, user } = ctx

const typeName = Astro.params.type!
const entityType = entityTypes.find(et => et.name === typeName)
if (!entityType || !entityType.schema) return Astro.redirect(`/apps/${container.slug}/${typeName}`)

const label = typeName.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase())
---

<AppLayout
  container={container}
  entityTypes={entityTypes}
  userName={user.email}
  userRole={user.role}
  activeType={typeName}
  breadcrumbs={[
    { label, href: `/apps/${container.slug}/${typeName}` },
    { label: 'New' },
  ]}
>
  <AppEntityFormIsland
    client:only="solid-js"
    containerId={container.id}
    slug={container.slug!}
    typeName={typeName}
    entityTypeId={entityType.id}
    schema={entityType.schema}
  />
</AppLayout>
