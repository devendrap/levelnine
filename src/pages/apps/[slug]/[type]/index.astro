---
import AppLayout from '../../../../layouts/AppLayout.astro'
import Pagination from '../../../../components/apps/Pagination.astro'
import EmptyState from '../../../../components/apps/EmptyState.astro'
import MasterDetailViewIsland from '../../../../islands/MasterDetailViewIsland.tsx'
import EntityDetailPanelIsland from '../../../../islands/EntityDetailPanelIsland.tsx'
import { loadAppContext, getUIConfig, getPages } from '../../../../lib/apps/helpers'
import * as entityService from '../../../../../server/modules/entities/service'

const ctx = await loadAppContext(Astro)
if (ctx instanceof Response) return ctx
const { container, entityTypes, user } = ctx

const typeName = Astro.params.type!
const entityType = entityTypes.find(et => et.name === typeName)
if (!entityType) return Astro.redirect(`/apps/${container.slug}`)

const status = Astro.url.searchParams.get('status') ?? undefined
const page = parseInt(Astro.url.searchParams.get('page') ?? '1')
const pageSize = 25

const result = await entityService.listEntities({
  type: typeName,
  container_id: container.id,
  status,
  page,
  pageSize,
})

const label = typeName.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase())
const statuses = ['all', 'draft', 'active', 'review', 'approved', 'archived']

// D10 UI config — use grid_config columns if available, else fall back to key_fields
const uiConfig = await getUIConfig(container.id, typeName)
const manifestEt = (container.manifest?.entity_types ?? []).find(e => e.name === typeName)

type ColDef = { field: string; label: string; width?: string; sortable?: boolean }
let columns: ColDef[] = []

if (uiConfig?.grid_config?.columns?.length) {
  columns = uiConfig.grid_config.columns
} else {
  // Fallback: key_fields from manifest
  const keyFields: string[] = (manifestEt as any)?.key_fields ?? []
  columns = keyFields.slice(0, 4).map(f => ({
    field: f,
    label: f.replace(/_/g, ' '),
  }))
}

const viewType = uiConfig?.view_type ?? 'full_page'
const isMasterDetail = viewType === 'master_detail' || viewType === 'grid_only'
const allPages = await getPages(container.id)
const paginationBaseUrl = `/apps/${container.slug}/${typeName}?${status ? `status=${status}&` : ''}page=`
---

<AppLayout
  container={container}
  entityTypes={entityTypes}
  userName={user.email}
  userRole={user.role}
  activeType={typeName}
  pages={allPages}
  breadcrumbs={[{ label }]}
>
  {isMasterDetail ? (
    <div class="h-[calc(100vh-56px)]">
      <MasterDetailViewIsland
        client:only="solid-js"
        containerId={container.id}
        slug={container.slug!}
        typeName={typeName}
        entityTypeId={entityType.id}
        schema={entityType.schema}
        columns={columns}
        entities={result.data.map(e => ({
          id: e.id, name: e.name, status: e.status,
          ...(e.content as Record<string, any> ?? {}),
        }))}
        total={result.total}
        splitRatio="40/60"
        detailConfig={uiConfig?.detail_config ?? null}
      />
    </div>
  ) : (
    <!-- Master-detail split view -->
    <div class="flex flex-col h-[calc(100vh-56px)]">
      <!-- Header bar -->
      <div
        class="flex items-center justify-between px-6 py-3 shrink-0"
        style="border-bottom:1px solid var(--ui-border)"
      >
        <div class="flex items-center gap-3">
          <h1 class="text-sm font-bold" style="color:var(--ui-text)">{label}</h1>
          {entityType.description && (
            <span class="text-[11px]" style="color:var(--ui-text-muted)">{entityType.description}</span>
          )}
          <span class="text-[11px]" style="color:var(--ui-text-placeholder)">
            {result.total} record{result.total !== 1 ? 's' : ''}
          </span>
        </div>
        <a
          href={`/apps/${container.slug}/${typeName}/new`}
          class="ui-btn ui-btn-primary ui-btn-sm"
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
          New {label}
        </a>
      </div>

      <!-- Status filters -->
      <div
        class="flex items-center gap-1 px-6 py-2 shrink-0"
        style="border-bottom:1px solid var(--ui-border)"
      >
        {statuses.map((s) => {
          const isActive = s === 'all' ? !status : status === s
          const href = s === 'all'
            ? `/apps/${container.slug}/${typeName}`
            : `/apps/${container.slug}/${typeName}?status=${s}`
          return (
            <a
              href={href}
              class="px-3 py-1 rounded-lg text-[11px] font-medium transition-all"
              style={isActive
                ? "background-color:rgba(212,164,74,0.12);color:var(--ui-primary)"
                : "color:var(--ui-text-muted)"
              }
            >
              {s.charAt(0).toUpperCase() + s.slice(1)}
            </a>
          )
        })}
      </div>

      <!-- Split pane -->
      <div class="flex flex-1 min-h-0">
        <!-- Left panel: entity list (server-rendered) -->
        <div
          class="overflow-auto scrollbar-thin shrink-0"
          style="width:62%;border-right:1px solid var(--ui-border)"
          id="entity-list-panel"
        >
          {result.data.length === 0 ? (
            <EmptyState
              icon={status ? 'search' : 'folder'}
              title={status ? `No ${status} records found` : `No ${label.toLowerCase()} records yet`}
              description={status ? 'Try adjusting your filters or create a new record.' : `Get started by creating your first ${label.toLowerCase()}.`}
              actionLabel={`Create New`}
              actionHref={`/apps/${container.slug}/${typeName}/new`}
            />
          ) : (
            <div>
              {result.data.map((entity) => {
                const badgeClass =
                  entity.status === 'approved' || entity.status === 'active' ? 'ui-badge ui-badge-success' :
                  entity.status === 'review' || entity.status === 'pending' ? 'ui-badge ui-badge-warning' :
                  entity.status === 'archived' ? 'ui-badge ui-badge-error' :
                  'ui-badge ui-badge-muted'
                return (
                  <button
                    type="button"
                    data-entity-id={entity.id}
                    class="entity-list-row w-full text-left flex items-center gap-3 px-5 py-3 transition-colors cursor-pointer"
                    style="border-bottom:1px solid var(--ui-border);background:transparent;border-left:none;border-right:none;border-top:none"
                  >
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 mb-0.5">
                        <span
                          class="text-[13px] font-medium truncate"
                          style="color:var(--ui-text)"
                        >
                          {entity.name}
                        </span>
                        <span class={badgeClass}>
                          {entity.status}
                        </span>
                      </div>
                      <div class="flex items-center gap-3">
                        {columns.slice(0, 2).map((col) => (
                          <span class="text-[11px] truncate max-w-[140px]" style="color:var(--ui-text-muted)">
                            {(entity.content as any)?.[col.field] ?? ''}
                          </span>
                        ))}
                        <span class="text-[11px]" style="color:var(--ui-text-placeholder)">
                          {new Date(entity.updated_at).toLocaleDateString()}
                        </span>
                      </div>
                    </div>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--ui-text-placeholder);flex-shrink:0">
                      <polyline points="9 18 15 12 9 6"/>
                    </svg>
                  </button>
                )
              })}

              <!-- Pagination -->
              {result.totalPages > 1 && (
                <Pagination
                  currentPage={page}
                  totalPages={result.totalPages}
                  baseUrl={paginationBaseUrl}
                />
              )}
            </div>
          )}
        </div>

        <!-- Right panel: detail (Solid island) -->
        <div class="flex-1 min-w-0 overflow-hidden" style="background-color:var(--ui-bg-subtle)">
          <EntityDetailPanelIsland
            client:only="solid-js"
            slug={container.slug!}
            typeName={typeName}
          />
        </div>
      </div>
    </div>

    <!-- Wire up selection: list buttons -> CustomEvent -> island -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const panel = document.getElementById('entity-list-panel')
        if (!panel) return

        let activeBtn: HTMLElement | null = null

        panel.addEventListener('click', (e) => {
          const btn = (e.target as HTMLElement).closest('[data-entity-id]') as HTMLElement | null
          if (!btn) return

          const entityId = btn.getAttribute('data-entity-id')
          if (!entityId) return

          // Update selected styling
          if (activeBtn) {
            activeBtn.style.backgroundColor = 'transparent'
          }
          btn.style.backgroundColor = 'var(--ui-primary-light)'
          activeBtn = btn

          // Dispatch event for the Solid island
          window.dispatchEvent(new CustomEvent('entity-selected', {
            detail: { entityId },
          }))
        })

        // Hover styles
        panel.addEventListener('mouseover', (e) => {
          const btn = (e.target as HTMLElement).closest('[data-entity-id]') as HTMLElement | null
          if (btn && btn !== activeBtn) {
            btn.style.backgroundColor = 'var(--ui-bg-hover)'
          }
        })
        panel.addEventListener('mouseout', (e) => {
          const btn = (e.target as HTMLElement).closest('[data-entity-id]') as HTMLElement | null
          if (btn && btn !== activeBtn) {
            btn.style.backgroundColor = 'transparent'
          }
        })
      })
    </script>
  )}
</AppLayout>
