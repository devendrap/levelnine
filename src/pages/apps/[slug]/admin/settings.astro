---
import AppLayout from '../../../../layouts/AppLayout.astro'
import StepWizard from '../../../../components/apps/StepWizard.astro'
import AvatarStack from '../../../../components/apps/AvatarStack.astro'
import { loadAppContext, getPages } from '../../../../lib/apps/helpers'
import * as entityService from '../../../../../server/modules/entities/service'

const ctx = await loadAppContext(Astro)
if (ctx instanceof Response) return ctx
const { container, entityTypes, user } = ctx

// Admin only
if (user.role !== 'admin') {
  return Astro.redirect(`/apps/${container.slug}`)
}

const allPages = await getPages(container.id)
const manifest = container.manifest as any

// Count seed entities for setup progress
const entityCounts = await entityService.countEntitiesByType(container.id)
const totalSeedRecords = entityCounts.reduce((sum, c) => sum + Number(c.total), 0)

// Setup progress: 0=Define Schema, 1=Generate Pages, 2=Seed Data (all done = 3)
const hasSchemas = entityTypes.length > 0
const hasPages = allPages.length > 0
const hasSeedData = totalSeedRecords > 0
const setupStep = hasSeedData ? 3 : hasPages ? 2 : hasSchemas ? 1 : 0

const setupSteps = [
  { label: 'Define Schema' },
  { label: 'Generate Pages' },
  { label: 'Seed Data' },
]

// Build role avatars for AvatarStack
const roleColors = ['#3B8FE8', '#D4A44A', '#E8553B', '#38B887', '#9B59B6', '#E67E22']
const manifestRoles = manifest?.roles ?? []
const roleUsers = manifestRoles.map((r: any, i: number) => ({
  name: r.label ?? r.name,
  color: roleColors[i % roleColors.length],
}))

// Compute some stats
const entityTypeCount = entityTypes.length
const roleCount = (manifest?.roles ?? []).length
const workflowCount = (manifest?.workflows ?? []).length
const complianceCount = (manifest?.compliance ?? []).length
const pageCount = allPages.length
const notificationCount = (manifest?.notifications ?? []).length
---

<AppLayout
  container={container}
  entityTypes={entityTypes}
  userName={user.email}
  userRole={user.role}
  activePage="admin-settings"
  pages={allPages}
  breadcrumbs={[{ label: 'Admin' }, { label: 'Settings' }]}
>
  <div class="max-w-4xl mx-auto px-8 py-8" data-container-id={container.id}>
    <div class="mb-6">
      <h1 class="text-xl font-bold" style="color:var(--ui-text)">Settings</h1>
      <p class="text-sm mt-1" style="color:var(--ui-text-muted)">
        Application configuration for {container.name}
      </p>
    </div>

    <!-- App info -->
    <div
      class="rounded-xl p-6 mb-6"
      style="background-color:var(--ui-bg-subtle);border:1px solid var(--ui-border)"
    >
      <h3 class="text-sm font-semibold mb-4" style="color:var(--ui-text)">Application Info</h3>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <span class="text-[11px] uppercase tracking-wider" style="color:var(--ui-text-placeholder)">Name</span>
          <p class="text-sm mt-0.5" style="color:var(--ui-text)">{container.name}</p>
        </div>
        <div>
          <span class="text-[11px] uppercase tracking-wider" style="color:var(--ui-text-placeholder)">Slug</span>
          <p class="text-sm mt-0.5" style="color:var(--ui-text)">{container.slug}</p>
        </div>
        <div>
          <span class="text-[11px] uppercase tracking-wider" style="color:var(--ui-text-placeholder)">Status</span>
          <p class="text-sm mt-0.5" style="color:var(--ui-text)">{container.status}</p>
        </div>
        <div>
          <span class="text-[11px] uppercase tracking-wider" style="color:var(--ui-text-placeholder)">Created</span>
          <p class="text-sm mt-0.5" style="color:var(--ui-text)">{new Date(container.created_at).toLocaleDateString()}</p>
        </div>
        {container.description && (
          <div class="col-span-2">
            <span class="text-[11px] uppercase tracking-wider" style="color:var(--ui-text-placeholder)">Description</span>
            <p class="text-sm mt-0.5" style="color:var(--ui-text)">{container.description}</p>
          </div>
        )}
      </div>
    </div>

    <!-- Manifest overview -->
    <div
      class="rounded-xl p-6 mb-6"
      style="background-color:var(--ui-bg-subtle);border:1px solid var(--ui-border)"
    >
      <h3 class="text-sm font-semibold mb-4" style="color:var(--ui-text)">Manifest Overview</h3>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <div class="rounded-lg p-4" style="background-color:var(--ui-bg)">
          <div class="text-xl font-bold" style="color:var(--ui-primary)">{entityTypeCount}</div>
          <div class="text-xs" style="color:var(--ui-text-muted)">Entity Types</div>
        </div>
        <div class="rounded-lg p-4" style="background-color:var(--ui-bg)">
          <div class="text-xl font-bold" style="color:var(--ui-primary)">{roleCount}</div>
          <div class="text-xs" style="color:var(--ui-text-muted)">Roles</div>
        </div>
        <div class="rounded-lg p-4" style="background-color:var(--ui-bg)">
          <div class="text-xl font-bold" style="color:var(--ui-primary)">{workflowCount}</div>
          <div class="text-xs" style="color:var(--ui-text-muted)">Workflows</div>
        </div>
        <div class="rounded-lg p-4" style="background-color:var(--ui-bg)">
          <div class="text-xl font-bold" style="color:var(--ui-primary)">{complianceCount}</div>
          <div class="text-xs" style="color:var(--ui-text-muted)">Compliance Rules</div>
        </div>
        <div class="rounded-lg p-4" style="background-color:var(--ui-bg)">
          <div class="text-xl font-bold" style="color:var(--ui-primary)">{pageCount}</div>
          <div class="text-xs" style="color:var(--ui-text-muted)">Custom Pages</div>
        </div>
        <div class="rounded-lg p-4" style="background-color:var(--ui-bg)">
          <div class="text-xl font-bold" style="color:var(--ui-primary)">{notificationCount}</div>
          <div class="text-xs" style="color:var(--ui-text-muted)">Notifications</div>
        </div>
      </div>
    </div>

    <!-- Roles -->
    {roleCount > 0 && (
      <div
        class="rounded-xl p-6 mb-6"
        style="background-color:var(--ui-bg-subtle);border:1px solid var(--ui-border)"
      >
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-semibold" style="color:var(--ui-text)">Domain Roles</h3>
          <AvatarStack users={roleUsers} size="sm" max={6} />
        </div>
        <div class="space-y-3">
          {(manifest.roles as any[]).map((role: any) => (
            <div class="rounded-lg p-4" style="background-color:var(--ui-bg)">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-sm font-medium" style="color:var(--ui-text)">{role.label}</span>
                <span class="text-[11px] px-2 py-0.5 rounded-full" style="background-color:rgba(240,237,232,0.06);color:var(--ui-text-muted)">
                  {role.name}
                </span>
              </div>
              <p class="text-xs" style="color:var(--ui-text-muted)">{role.description}</p>
              <div class="flex flex-wrap gap-1 mt-2">
                {(role.permissions as string[]).slice(0, 6).map((perm: string) => (
                  <span class="text-[10px] px-1.5 py-0.5 rounded" style="background-color:rgba(59,143,232,0.1);color:var(--ui-accent)">
                    {perm}
                  </span>
                ))}
                {role.permissions.length > 6 && (
                  <span class="text-[10px] px-1.5 py-0.5" style="color:var(--ui-text-placeholder)">
                    +{role.permissions.length - 6} more
                  </span>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Generate Pages & Seed Data -->
    <div
      class="rounded-xl p-6 mb-6"
      style="background-color:var(--ui-bg-subtle);border:1px solid var(--ui-border)"
    >
      <h3 class="text-sm font-semibold mb-3" style="color:var(--ui-text)">Dashboard & Seed Data</h3>
      <div class="mb-4">
        <StepWizard steps={setupSteps} currentStep={setupStep} />
      </div>
      <p class="text-xs mb-4" style="color:var(--ui-text-muted)">
        Generate custom dashboard pages and realistic seed data using AI. This creates a Home page with widgets, domain-specific pages, and sample records for key entity types.
        {pageCount > 0 && ` Currently ${pageCount} page(s) configured — regenerating will replace them.`}
      </p>
      <div class="flex items-center gap-3">
        <button
          id="generate-pages-btn"
          class="px-4 py-2 rounded-lg text-sm font-medium transition-colors cursor-pointer"
          style="background-color:var(--ui-primary);color:var(--ui-bg)"
        >
          Generate Dashboard & Seed Data
        </button>
        <span id="generate-pages-status" class="text-xs" style="color:var(--ui-text-muted)"></span>
      </div>
    </div>

    <!-- App URL -->
    <div
      class="rounded-xl p-6"
      style="background-color:var(--ui-bg-subtle);border:1px solid var(--ui-border)"
    >
      <h3 class="text-sm font-semibold mb-2" style="color:var(--ui-text)">App URL</h3>
      <div class="flex items-center gap-2">
        <code class="text-xs px-3 py-2 rounded-lg flex-1" style="background-color:var(--ui-bg);color:var(--ui-text-muted)">
          /apps/{container.slug}
        </code>
      </div>
    </div>
  </div>

  <script>
    const btn = document.getElementById('generate-pages-btn') as HTMLButtonElement
    const status = document.getElementById('generate-pages-status')!

    btn.addEventListener('click', async () => {
      btn.disabled = true
      btn.style.opacity = '0.5'
      status.textContent = 'Generating pages and seed data...'

      try {
        const containerId = btn.closest('[data-container-id]')?.getAttribute('data-container-id')
        if (!containerId) throw new Error('Container ID not found')
        const res = await fetch(`/api/v1/containers/${containerId}/generate-pages`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ provider: 'ollama' }),
          credentials: 'include',
        })

        if (!res.ok) {
          const err = await res.json()
          throw new Error(err.error || 'Generation failed')
        }

        const result = await res.json()
        status.textContent = `Done! ${result.pages.length} page(s) + ${result.seedCount} seed records created.`
        status.style.color = 'var(--ui-success)'

        // Reload after short delay
        setTimeout(() => window.location.reload(), 1500)
      } catch (err: any) {
        status.textContent = `Error: ${err.message}`
        status.style.color = 'var(--ui-danger)'
        btn.disabled = false
        btn.style.opacity = '1'
      }
    })
  </script>
</AppLayout>
