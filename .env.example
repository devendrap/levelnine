# Environment
NODE_ENV=development
BASE_URL=http://localhost:4321

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5433
DB_USER=aiui
DB_PASSWORD=aiui_dev
DB_NAME=aiui

# Auth
JWT_SECRET=ai-ui-dev-secret-change-in-prod
JWT_EXPIRES_IN=24h

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=aiui
S3_SECRET_KEY=aiui_dev_secret
S3_BUCKET=ai-ui-uploads

# LLM Providers (uncomment as needed)
# OPENAI_API_KEY=
# XAI_API_KEY=
# GEMINI_API_KEY=

# Container System Prompt (the "superhero auditor" persona for LLM chat)
# CONTAINER_SYSTEM_PROMPT=

# Prompt Templates (use {{name}}, {{count}}, {{names}}, {{remaining}} placeholders)
# ENHANCE_PROMPT=Generate the full detailed JSON schema for "{{name}}". Include every field a practitioner would need, use appropriate ai-ui components (Tabs for sections, Select for dropdowns, DatePicker for dates, FileUpload for documents, RichText for notes). Make it production-ready.
# PARALLEL_SCHEMA_PROMPT=Generate the full detailed JSON schema for "{{name}}" ({{description}}). Use appropriate ai-ui components. Key fields: {{key_fields}}. Respond with ONLY a valid JSON object.
# GENERATE_SCHEMAS_PROMPT=Generate full JSON schemas for these {{count}} entity types: {{names}}\n\nFor each, use appropriate ai-ui components (Tabs, Select, DatePicker, FileUpload, RichText, Table, Checkbox). Be thorough but concise.\n\nIMPORTANT: In the json:entity_types summary block at the end, include ONLY these {{count}} entity types with their schemas. Do NOT include the other {{remaining}} entity types.
